---
/**
 * 指標へのインラインリンク + ツールチップ。
 * 指標解説記事へのリンクを生成し、ホバーで短い説明を表示。
 *
 * 使い方（MDX内）:
 * ```mdx
 * <Metric id="stuff-plus">Stuff+</Metric>が132に上昇した。
 * ```
 */
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<a href={`/metrics/${id}`} class="metric-link" data-metric-id={id}>
  <slot />
</a>

<style>
  .metric-link {
    color: var(--color-accent, #2563eb);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
    cursor: help;
  }

  .metric-link:hover {
    text-decoration-style: solid;
  }
</style>
