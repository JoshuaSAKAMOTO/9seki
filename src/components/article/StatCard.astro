---
/**
 * 数字を主役にするスタットカード。
 * 大きな数字 + ラベル + パーセンタイルバー（任意）。
 *
 * 使い方:
 * <StatCard
 *   label="Whiff%"
 *   value="42.1"
 *   unit="%"
 *   percentile={95}
 *   note="リーグ上位5%水準"
 * />
 */
interface Props {
  label: string;
  value: string | number;
  unit?: string;
  percentile?: number;
  note?: string;
}

const { label, value, unit, percentile, note } = Astro.props;
---

<div class="stat-card">
  <p class="stat-label">{label}</p>
  <p class="stat-value">
    <span class="num">{value}</span>
    {unit && <span class="stat-unit">{unit}</span>}
  </p>
  {
    percentile !== undefined && (
      <div class="stat-percentile">
        <div class="percentile-bar">
          <div class="percentile-fill" style={`width: ${percentile}%`} />
        </div>
        <span class="percentile-label num">{percentile}パーセンタイル</span>
      </div>
    )
  }
  {note && <p class="stat-note">{note}</p>}
</div>

<style>
  .stat-card {
    padding: 1.25rem 1rem;
    margin: 1.5rem 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .stat-label {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-value {
    margin: 0.25rem 0 0;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    font-family: var(--font-num);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .stat-unit {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .stat-percentile {
    margin-top: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .percentile-bar {
    width: 100%;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .percentile-fill {
    height: 100%;
    background: var(--color-accent);
  }

  .percentile-label {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  .stat-note {
    margin: 0.5rem 0 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
