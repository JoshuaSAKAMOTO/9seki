---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  api,
  playerSlug,
  roleLabel,
  type Player,
  type GameLog,
  type BatterGameStats,
  type PitcherGameStats,
} from "@/lib/api";

export async function getStaticPaths() {
  const players = await api.listPlayers();
  const entries = await Promise.all(
    players.map(async (p) => {
      const logs = await api.getGameLogs(p.mlbam_id, { limit: 10 });
      return {
        params: { slug: playerSlug(p) },
        props: { player: p, logs },
      };
    }),
  );
  return entries;
}

interface Props {
  player: Player;
  logs: GameLog[];
}

const { player, logs } = Astro.props;

const pitcherLogs = logs.filter((l) => l.role === "pitcher");
const batterLogs = logs.filter((l) => l.role === "batter");

const fmt = (n: number | null | undefined, digits = 1) =>
  n == null ? "—" : n.toFixed(digits);
const fmtRate = (n: number | null | undefined) =>
  n == null ? "—" : (n * 100).toFixed(1);
const fmtAvg = (n: number | null | undefined) =>
  n == null ? "—" : n.toFixed(3).replace(/^0/, "");

const buildDate = new Date().toISOString().slice(0, 10);
---

<BaseLayout
  title={player.name_ja}
  description={`${player.name_ja} (${player.name_en}) の最新試合ログ — 球析`}
>
  <header class="player-header">
    <p class="role-tag" data-role={player.primary_role}>
      {roleLabel(player.primary_role)}
    </p>
    <h1 class="player-name">
      <span class="name-ja">{player.name_ja}</span>
      <span class="name-en">{player.name_en}</span>
    </h1>
    <dl class="player-meta">
      <div>
        <dt>チーム</dt>
        <dd class="num">{player.team_code}</dd>
      </div>
      <div>
        <dt>MLBAM ID</dt>
        <dd class="num">{player.mlbam_id}</dd>
      </div>
      {
        player.jersey_number && (
          <div>
            <dt>背番号</dt>
            <dd class="num">{player.jersey_number}</dd>
          </div>
        )
      }
    </dl>
  </header>

  {
    batterLogs.length > 0 && (
      <section class="logs">
        <h2>打撃ログ（直近{batterLogs.length}試合）</h2>
        <div class="log-table-wrap">
          <table class="log-table">
            <thead>
              <tr>
                <th>日付</th>
                <th class="num-col">AB</th>
                <th class="num-col">H</th>
                <th class="num-col">HR</th>
                <th class="num-col">BB</th>
                <th class="num-col">K</th>
                <th class="num-col">AVG</th>
              </tr>
            </thead>
            <tbody>
              {batterLogs.map((log) => {
                const s = log.stats as BatterGameStats;
                return (
                  <tr>
                    <td>{log.game_date}</td>
                    <td class="num">{s.ab ?? "—"}</td>
                    <td class="num">{s.hits ?? "—"}</td>
                    <td class="num">{s.home_runs ?? "—"}</td>
                    <td class="num">{s.walks ?? "—"}</td>
                    <td class="num">{s.strikeouts ?? "—"}</td>
                    <td class="num">{fmtAvg(s.avg)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )
  }

  {
    pitcherLogs.length > 0 && (
      <section class="logs">
        <h2>投球ログ（直近{pitcherLogs.length}試合）</h2>
        <div class="log-table-wrap">
          <table class="log-table">
            <thead>
              <tr>
                <th>日付</th>
                <th class="num-col">球数</th>
                <th class="num-col">打者</th>
                <th class="num-col">Whiff%</th>
                <th class="num-col">CSW%</th>
                <th class="num-col">平均球速</th>
              </tr>
            </thead>
            <tbody>
              {pitcherLogs.map((log) => {
                const s = log.stats as PitcherGameStats;
                const avgKmh =
                  s.avg_velocity_mph != null
                    ? (s.avg_velocity_mph * 1.609).toFixed(1)
                    : "—";
                return (
                  <tr>
                    <td>{log.game_date}</td>
                    <td class="num">{s.pitches ?? "—"}</td>
                    <td class="num">{s.batters_faced ?? "—"}</td>
                    <td class="num">{fmtRate(s.whiff_rate)}</td>
                    <td class="num">{fmtRate(s.csw_rate)}</td>
                    <td class="num">{avgKmh}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )
  }

  {
    logs.length === 0 && (
      <p class="empty">
        まだ試合ログが取得できていません。シーズン初期またはこの期間は出場がなかった可能性があります。
      </p>
    )
  }

  <footer class="build-stamp">
    <p>
      <span class="num">{buildDate}</span> 時点のビルドデータ。
      最新の生データは
      <a
        href={`https://9seki-api.josh-8b9.workers.dev/api/players/${player.mlbam_id}/game-logs?limit=10`}
        target="_blank"
        rel="noopener"
      >
        API
      </a>
      で直接確認できる。
    </p>
  </footer>
</BaseLayout>

<style>
  .player-header {
    padding: 1rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .role-tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .role-tag[data-role="two_way"] {
    color: #c2410c;
  }

  .player-name {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .name-ja {
    font-size: 1.75rem;
  }

  .name-en {
    font-family: var(--font-num);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .player-meta {
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 0.75rem;
    font-size: 0.8125rem;
  }

  .player-meta dt {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.125rem;
  }

  .player-meta dd {
    font-weight: 700;
  }

  .logs {
    margin-top: 2rem;
  }

  .logs h2 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-muted);
  }

  .log-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
  }

  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }

  .log-table th,
  .log-table td {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .log-table th {
    font-weight: 600;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--color-bg);
  }

  .log-table tbody tr:last-child td {
    border-bottom: none;
  }

  .log-table .num,
  .log-table .num-col {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .empty {
    padding: 2rem 0;
    color: var(--color-text-muted);
  }

  .build-stamp {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
