---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Advanced from "@/components/article/Advanced.astro";
import Metric from "@/components/article/Metric.astro";
import StatCard from "@/components/article/StatCard.astro";
import HBarChart from "@/components/charts/HBarChart.astro";

export async function getStaticPaths() {
  const metrics = await getCollection("metrics");
  return metrics.map((metric) => ({
    params: { slug: metric.id },
    props: { metric },
  }));
}

const { metric } = Astro.props;
const { Content } = await render(metric);

const levelLabel = {
  basic: "基礎",
  intermediate: "中級",
  advanced: "上級",
}[metric.data.level];

const components = { Advanced, Metric, StatCard, HBarChart };
---

<BaseLayout title={metric.data.nameJa} description={metric.data.shortDesc}>
  <article class="metric-page">
    <header class="metric-header">
      <p class="metric-tag">指標解説</p>
      <h1 class="metric-name">
        <span class="name-ja">{metric.data.nameJa}</span>
        {
          metric.data.nameEn !== metric.data.nameJa && (
            <span class="name-en">{metric.data.nameEn}</span>
          )
        }
      </h1>
      <p class="metric-desc">{metric.data.shortDesc}</p>
      <dl class="metric-meta">
        <div>
          <dt>出典</dt>
          <dd>{metric.data.source}</dd>
        </div>
        {metric.data.unit && (
          <div>
            <dt>単位</dt>
            <dd>{metric.data.unit}</dd>
          </div>
        )}
        <div>
          <dt>レベル</dt>
          <dd>{levelLabel}</dd>
        </div>
        {metric.data.leagueAverage !== undefined && (
          <div>
            <dt>リーグ平均</dt>
            <dd class="num">{metric.data.leagueAverage}</dd>
          </div>
        )}
      </dl>
    </header>

    <div class="metric-body">
      <Content components={components} />
    </div>

    {
      metric.data.relatedMetrics.length > 0 && (
        <footer class="related">
          <h2>関連指標</h2>
          <ul>
            {metric.data.relatedMetrics.map((id) => (
              <li>
                <a href={`/metrics/${id}`}>{id}</a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }
  </article>
</BaseLayout>

<style>
  .metric-header {
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .metric-tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .metric-name {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .name-ja {
    font-size: 1.75rem;
  }

  .name-en {
    font-family: var(--font-num);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .metric-desc {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .metric-meta {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.75rem;
    font-size: 0.8125rem;
  }

  .metric-meta dt {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.125rem;
  }

  .metric-meta dd {
    font-weight: 600;
  }

  .metric-body :global(h2) {
    margin-top: 2.5rem;
    font-size: 1.25rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--color-border);
  }

  .metric-body :global(p) {
    line-height: 1.9;
  }

  .related {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .related h2 {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .related ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related a {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
</style>
